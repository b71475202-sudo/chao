-- CẤU HÌNH SCRIPT (VIẾT BẰNG LUA)
local LINK_NHAC = "https://pastebin.com" -- Thay link chứa nốt nhạc của bạn vào đây
local TOC_DO = 0.1 -- Thời gian trễ giữa các nốt (giây)

-- Khởi tạo công cụ hệ thống
local VirtualInputManager = game:GetService("VirtualInputManager")
local function bamPhim(chuCai)
    local keyCode
    pcall(function() keyCode = Enum.KeyCode[string.upper(chuCai)] end)
    if keyCode then
        if keypress and keyrelease then
            keypress(keyCode.Value)
            task.wait(0.01)
            keyrelease(keyCode.Value)
        else
            VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
            task.wait(0.01)
            VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
        end
    end
end

-- Tải dữ liệu từ link nhạc bạn đã gắn
print("Dang tai bai hat...")
local success, sheetNhac = pcall(function() return game:HttpGet(LINK_NHAC) end)

if not success or not sheetNhac then
    warn("Loi: Khong the tai du lieu tu link nay!")
    return
end

print("Bat dau tu dong danh piano sau 3 giay...")
task.wait(3) -- Cho bạn 3 giây để bấm chuột chọn cây đàn trong game

-- Vòng lặp đọc dữ liệu Lua để tách nốt
local i = 1
while i <= #sheetNhac do
    local kyTu = sheetNhac:sub(i, i)
    
    if kyTu == "[" then
        -- Xu ly hop am danh cung luc (vi du: [tup])
        local hopAm = ""
        i = i + 1
        while i <= #sheetNhac do
            local kyTuTiepTheo = sheetNhac:sub(i, i)
            if kyTuTiepTheo == "]" then break end
            hopAm = hopAm .. kyTuTiepTheo
            i = i + 1
        end
        for not trong hopAm:gmatch(".") do
            task.spawn(bamPhim, not)
        end
    elseif kyTu:match("%s") or kyTu == "|" or kyTu == "-" then
        task.wait(TOC_DO)
    else
        bamPhim(kyTu)
    end
    
    task.wait(TOC_DO)
    i = i + 1
end
print("Da danh xong bai hat!")
