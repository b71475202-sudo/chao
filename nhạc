-- Biến kiểm soát trạng thái phát nhạc
local VirtualInputManager = game:GetService("VirtualInputManager")
local isPlaying = false

-- Hàm mô phỏng phím bấm vật lý
local function tapKey(key)
	local keyCode
	pcall(function()
		keyCode = Enum.KeyCode[key]
	end)
	if keyCode then
		VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
		task.wait(0.01)
		VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
	end
end

-- Xử lý nút Phát nhạc
PlayBtn.MouseButton1Click:Connect(function()
	if isPlaying then return end
	
	local url = UrlInput.Text
	if url == "" then
		Status.Text = "Lỗi: Vui lòng nhập link sheet nhạc!"
		return
	end
	
	Status.Text = "Đang tải bài hát từ link..."
	
	-- Tải dữ liệu từ Link
	local success, musicSheet = pcall(function()
		return game:HttpGet(url)
	end)
	
	if not success or not musicSheet then
		Status.Text = "Lỗi: Không thể lấy dữ liệu từ link này!"
		return
	end
	
	isPlaying = true
	Status.Text = "Đang phát nhạc tự động..."
	
	-- Phân tích và xử lý chuỗi nốt nhạc
	task.spawn(function()
		local i = 1
		local delayTime = tonumber(DelayInput.Text) or 0.1
		
		while i <= #musicSheet and isPlaying do
			local char = musicSheet:sub(i, i)
			
			if char == "[" then
				-- Xử lý hợp âm đánh cùng lúc ví dụ: [tup]
				local chord = ""
				i = i + 1
				while i <= #musicSheet do
					local nextChar = musicSheet:sub(i, i)
					if nextChar == "]" then break end
					chord = chord .. nextChar
					i = i + 1
				end
				-- Nhấn tất cả các phím trong hợp âm cùng một lúc
				for c in chord:gmatch(".") do
					if isPlaying then
						task.spawn(tapKey, c)
					end
				end
			elseif char:match("%s") or char == "|" or char == "-" then
				-- Gặp khoảng trắng hoặc ký tự phân cách thì nghỉ ngắn
				task.wait(delayTime)
			else
				-- Gặp nốt đơn thông thường
				tapKey(char)
			end
			
			task.wait(delayTime)
			i = i + 1
		end
		
		isPlaying = false
		Status.Text = "Trạng thái: Đã phát xong hoặc đã dừng!"
	end)
end)

-- Xử lý nút Dừng
StopBtn.MouseButton1Click:Connect(function()
